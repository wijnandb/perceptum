---
import '@fontsource-variable/inter';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Perceptum ontwikkelt digitale oplossingen en eigen producten. Opgericht door Wijnand Baretta, met 25+ jaar ervaring bij merken als Ajax, Vodafone, KPN en Rabobank.',
  ogImage = '/og-default.png',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const fullTitle = title === 'Home' ? 'Perceptum — Technologie die Werkt' : `${title} — Perceptum`;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="author" content="Wijnand Baretta" />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1"} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:locale" content="nl_NL" />
    <meta property="og:site_name" content="Perceptum" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />
    <meta name="theme-color" content="#0c1929" />

    <!-- Structured Data: Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Perceptum",
      "alternateName": "Perceptum B.V.",
      "url": "https://perceptum.nl",
      "logo": "https://perceptum.nl/favicon.svg",
      "description": "Perceptum ontwikkelt digitale oplossingen, platforms en eigen producten. Opgericht in 2008 door Wijnand Baretta na het succesvol opbouwen van digitaal bureau Pascolo (1999-2007, 35 medewerkers). Specialisaties: software op maat, digitale strategie en productinnovatie.",
      "foundingDate": "2008",
      "founder": {
        "@type": "Person",
        "name": "Wijnand Baretta",
        "jobTitle": "Oprichter & Directeur",
        "url": "https://perceptum.nl/over/",
        "sameAs": [
          "https://www.linkedin.com/in/wijnandbaretta/",
          "https://github.com/wijnandb"
        ],
        "knowsAbout": [
          "Software Development",
          "Digital Strategy",
          "AI & Machine Learning",
          "Product Development",
          "Entrepreneurship",
          "Fantasy Sports Platforms",
          "Mobile Technology",
          "EdTech"
        ],
        "description": "Nederlandse ondernemer en technoloog. Richtte in 1999 Pascolo op (digitaal bureau, 35 medewerkers, Amsterdam/Izmir). Bouwde voor Ajax, PSV, Feyenoord, Vodafone, KPN en Rabobank. Winnaar I-mode Vak Award 2005. Richtte in 2008 Perceptum op. Ontwikkelde het chirurgische trainingsplatform Incision (nu wereldwijd in gebruik). Oprichter van CodeCult (programmeeronderwijs voor kinderen, 2015-2023). Bijdrage aan Khan Academy Nederland."
      },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Noordwijk",
        "addressRegion": "Zuid-Holland",
        "addressCountry": "NL"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+31-71-203-2103",
        "email": "wijnand@perceptum.nl",
        "contactType": "customer service",
        "availableLanguage": ["Dutch", "English"]
      },
      "sameAs": [
        "https://www.linkedin.com/in/wijnandbaretta/",
        "https://github.com/wijnandb"
      ],
      "knowsAbout": [
        "Software Development",
        "Digital Strategy",
        "AI Automation",
        "Product Development",
        "Fantasy Sports",
        "EdTech",
        "Mobile Applications"
      ]
    })} />

    <!-- Structured Data: WebSite (for Google sitelinks search) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Perceptum",
      "url": "https://perceptum.nl",
      "description": "Perceptum — Technologie die Werkt. Digitale oplossingen en eigen producten door Wijnand Baretta.",
      "publisher": {
        "@type": "Organization",
        "name": "Perceptum"
      }
    })} />

    <!-- Structured Data: SiteNavigationElement (helps Google show sitelinks) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SiteNavigationElement",
      "name": ["Diensten", "Producten", "Projecten", "Over Perceptum", "Contact"],
      "url": [
        "https://perceptum.nl/diensten/",
        "https://perceptum.nl/producten/",
        "https://perceptum.nl/projecten/",
        "https://perceptum.nl/over/",
        "https://perceptum.nl/contact/"
      ]
    })} />
    <!-- Analytics -->
    <script src="https://analytics.bollenstreekdigitaal.nl/liveview.js?key=lv_live_JR6fpvt5hiPzImcNK4doXVugxV7OXZXl" defer></script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Scroll animation observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.animate-on-scroll').forEach((el) => {
        observer.observe(el);
      });
    </script>
  </body>
</html>
