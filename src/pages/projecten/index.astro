---

<Layout
  title="Portfolio"
  description="Websites, platforms en eigen producten. Gebouwd door Wijnand Baretta — Perceptum."
>
  <section class="gradient-navy relative overflow-hidden -mt-20 pt-20">
    <!-- Conway's Game of Life -->
    <div class="absolute inset-0 overflow-hidden">
      <canvas id="conway" class="absolute inset-0 w-full h-full"></canvas>
    </div>
    <div class="container-narrow mx-auto px-6 py-20 md:py-28 relative z-10">
      <h1 class="heading-xl text-white mb-6">Portfolio</h1>
      <p class="text-xl text-slate-300 max-w-2xl">
        Websites, platforms en eigen producten. Alles gebouwd door een persoon, met hulp van AI. Geen team, geen overhead — gewoon goed werk.
      </p>
    </div>
    <div class="relative h-12 md:h-20">
      <svg class="absolute bottom-0 w-full h-full" viewBox="0 0 1440 80" fill="none" preserveAspectRatio="none">
        <path d="M0 80L720 40L1440 80H0Z" fill="#f8fafc"/>
      </svg>
    </div>
  </section>

  <!-- Timeline -->
  <section class="section-padding">
    <div class="container-narrow mx-auto">

      {eras.map((era, eraIndex) => (
        <div class={`relative ${eraIndex > 0 ? 'mt-20' : ''}`}>

          {/* Era header */}
          <div class="flex items-center gap-4 mb-10 animate-on-scroll">
            <div class="flex items-center gap-3">
              <div class={`w-4 h-4 rounded-full ${eraIndex === 0 ? 'bg-accent shadow-lg shadow-accent/30' : 'bg-slate-300'}`}>
                {eraIndex === 0 && (
                  <div class="w-4 h-4 rounded-full bg-accent animate-ping opacity-30" />
                )}
              </div>
              <h2 class="heading-lg text-navy-900">{era.label}</h2>
            </div>
            <span class="text-sm text-slate-400 font-medium">{era.period}</span>
            <div class="flex-1 h-px bg-slate-200" />
          </div>

          {/* Projects in this era */}
          <div class="relative ml-2 pl-8 border-l-2 border-slate-200">
            <div class="space-y-8">
              {era.projects.map((project) => (
                <div id={project.id} class="relative animate-on-scroll">
                  {/* Timeline dot */}
                  <div class={`absolute -left-[calc(2rem+5px)] top-2 w-3 h-3 rounded-full border-2 ${
                    project.status
                      ? 'bg-emerald-500 border-emerald-500'
                      : 'bg-white border-slate-300'
                  }`} />

                  <div class={`card p-6 md:p-8 ${project.status ? 'border-emerald-200/60 hover:border-emerald-300/60' : ''}`}>
                    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-3 mb-3">
                      <div>
                        <div class="flex items-center gap-3 flex-wrap">
                          <h3 class="heading-sm text-navy-900">{project.name}</h3>
                          {project.status && (
                            <span class="text-xs font-semibold px-3 py-1 rounded-full bg-emerald-100 text-emerald-700 flex items-center gap-1.5">
                              <span class="w-1.5 h-1.5 rounded-full bg-emerald-500" />
                              {project.status}
                            </span>
                          )}
                        </div>
                        <div class="flex items-center gap-2 mt-1">
                          <span class="text-sm text-slate-400">{project.period}</span>
                          {project.client && (
                            <>
                              <span class="text-slate-300">&middot;</span>
                              <span class="text-sm text-accent font-medium">{project.client}</span>
                            </>
                          )}
                        </div>
                      </div>
                    </div>

                    <p class="text-slate-600 leading-relaxed mb-4">{project.description}</p>

                    {project.image && (
                      <div class="mb-4 rounded-lg overflow-hidden border border-slate-200/60 shadow-sm">
                        <img src={project.image} alt={`Screenshot van ${project.name}`} class="w-full h-auto" loading="lazy" />
                      </div>
                    )}

                    {project.tags && (
                      <div class="flex flex-wrap gap-2">
                        {project.tags.map((tag) => (
                          <span class="text-xs px-2.5 py-1 rounded-full bg-slate-100 text-slate-500 font-medium">{tag}</span>
                        ))}
                      </div>
                    )}

                    {project.href && (
                      <a href={project.href} class="inline-flex items-center gap-1 text-sm font-medium text-accent mt-4 hover:underline">
                        Meer over {project.name}
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                        </svg>
                      </a>
                    )}

                    {project.externalHref && (
                      <a href={project.externalHref} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-sm font-medium text-accent mt-4 hover:underline">
                        Bekijk {project.name}
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                      </a>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}



    </div>
  </section>

  <CTA
    heading="Iets soortgelijks nodig?"
    subtitle="Ik bouw graag mee. Vertel me wat u in gedachten heeft -- een kort gesprek is vaak genoeg."
  />
</Layout>

<script>
  const canvas = document.getElementById('conway') as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    const cellSize = 8;
    let cols: number, rows: number;
    let grid: Uint8Array;
    const cellColor = 'rgba(59,130,246,0.4)';

    function resize() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
      cols = Math.ceil(canvas.width / cellSize);
      rows = Math.ceil(canvas.height / cellSize);
      grid = new Uint8Array(cols * rows);
      for (let i = 0; i < grid.length; i++) {
        grid[i] = Math.random() < 0.3 ? 1 : 0;
      }
    }

    function step() {
      const next = new Uint8Array(cols * rows);
      for (let y = 0; y < rows; y++) {
        for (let x = 0; x < cols; x++) {
          let n = 0;
          for (let dy = -1; dy <= 1; dy++) {
            for (let dx = -1; dx <= 1; dx++) {
              if (dx === 0 && dy === 0) continue;
              n += grid[((y + dy + rows) % rows) * cols + ((x + dx + cols) % cols)];
            }
          }
          const i = y * cols + x;
          if (grid[i]) {
            next[i] = (n === 2 || n === 3) ? 1 : 0;
          } else {
            next[i] = n === 3 ? 1 : 0;
          }
        }
      }
      grid = next;
    }

    function draw() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.fillStyle = cellColor;
      for (let y = 0; y < rows; y++) {
        for (let x = 0; x < cols; x++) {
          if (grid[y * cols + x]) {
            ctx.fillRect(x * cellSize + 1, y * cellSize + 1, cellSize - 2, cellSize - 2);
          }
        }
      }
    }

    resize();
    window.addEventListener('resize', resize);

    let last = 0;
    function loop(t: number) {
      if (t - last > 200) {
        step();
        draw();
        last = t;
      }
      requestAnimationFrame(loop);
    }
    requestAnimationFrame(loop);
  }
</script>
