  return p.href || p.externalHref;
}

function isExternal(p: Project) {
  return !!p.externalHref;
}
---

<Layout
  title="Projecten"
  description="Websites, platforms en eigen producten. Gebouwd door Perceptum."
>
  <!-- Hero -->
  <section class="gradient-navy relative overflow-hidden -mt-20 pt-20">
    <div class="absolute inset-0 overflow-hidden">
      <canvas id="conway" class="absolute inset-0 w-full h-full"></canvas>
    </div>
    <div class="container-narrow mx-auto px-6 py-20 md:py-28 relative z-10">
      <h1 class="heading-xl text-white mb-6">Projecten</h1>
      <p class="text-xl text-slate-300 max-w-2xl">
        Websites, platforms en eigen producten. Gebouwd door Perceptum.
      </p>
    </div>
    <div class="relative h-12 md:h-20">
      <svg class="absolute bottom-0 w-full h-full" viewBox="0 0 1440 80" fill="none" preserveAspectRatio="none">
        <path d="M0 80L720 40L1440 80H0Z" fill="#f8fafc"/>
      </svg>
    </div>
  </section>

  <!-- Featured projects -->
  <section class="section-padding">
    <div class="container-narrow mx-auto">
      <div class="flex items-center gap-4 mb-12 animate-on-scroll">
        <div class="w-4 h-4 rounded-full bg-accent shadow-lg shadow-accent/30">
          <div class="w-4 h-4 rounded-full bg-accent animate-ping opacity-30"></div>
        </div>
        <h2 class="heading-lg text-navy-900">Uitgelicht</h2>
        <div class="flex-1 h-px bg-slate-200"></div>
      </div>

      <div class="space-y-16">
        {featured.map((project, i) => (
          <div class={`animate-on-scroll delay-${i + 1}`}>
            <div class="card overflow-hidden">
              {project.image && (
                <div class="aspect-[21/9] overflow-hidden bg-slate-100">
                  <img
                    src={project.image}
                    alt={`Screenshot van ${project.name}`}
                    class="w-full h-full object-cover object-top"
                    loading={i === 0 ? 'eager' : 'lazy'}
                  />
                </div>
              )}
              <div class="p-8 md:p-10">
                <div class="flex items-center gap-3 flex-wrap mb-2">
                  <h3 class="heading-md text-navy-900">{project.name}</h3>
                  {project.status && (
                    <span class="text-xs font-semibold px-3 py-1 rounded-full bg-emerald-100 text-emerald-700 flex items-center gap-1.5">
                      <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                      {project.status}
                    </span>
                  )}
                </div>
                <div class="flex items-center gap-2 mb-6">
                  <span class="text-sm text-slate-400">{project.period}</span>
                  {project.client && (
                    <>
                      <span class="text-slate-300">&middot;</span>
                      <span class="text-sm text-accent font-medium">{project.client}</span>
                    </>
                  )}
                </div>

                <div class="grid md:grid-cols-3 gap-6 md:gap-8">
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2">Situatie</p>
                    <p class="text-slate-600 leading-relaxed">{project.situation}</p>
                  </div>
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2">Oplossing</p>
                    <p class="text-slate-600 leading-relaxed">{project.solution}</p>
                  </div>
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2">Resultaat</p>
                    <p class="text-slate-600 leading-relaxed">{project.result}</p>
                  </div>
                </div>

                <div class="flex items-center justify-between mt-8 pt-6 border-t border-slate-100">
                  {project.tags && (
                    <div class="flex flex-wrap gap-2">
                      {project.tags.map((tag) => (
                        <span class="text-xs px-2.5 py-1 rounded-full bg-slate-100 text-slate-500 font-medium">{tag}</span>
                      ))}
                    </div>
                  )}
                  {(project.href || project.externalHref) && (
                    <a
                      href={projectLink(project)}
                      target={isExternal(project) ? '_blank' : undefined}
                      rel={isExternal(project) ? 'noopener noreferrer' : undefined}
                      class="inline-flex items-center gap-1 text-sm font-medium text-accent hover:underline shrink-0"
                    >
                      Bekijk project
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        {isExternal(project) ? (
