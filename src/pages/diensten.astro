---
import Layout from '../layouts/Layout.astro';
import CTA from '../components/CTA.astro';
---

<Layout
  title="Diensten"
  description="Perceptum bouwt software, automatiseert werkprocessen en beheert platforms. Zodat u zich kunt richten op het werk dat ertoe doet."
>
  <section class="gradient-navy relative overflow-hidden -mt-20 pt-20">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="container-narrow mx-auto px-6 py-20 md:py-28 relative z-10">
      <div class="flex items-center gap-8">
        <div class="flex-1">
          <h1 class="heading-xl text-white mb-6">Wat wij doen</h1>
          <p class="text-xl text-slate-300 max-w-2xl">
            Wij bouwen software en automatiseren werkprocessen. Zodat mensen zich kunnen richten op het werk waar ze goed in zijn en plezier aan beleven.
          </p>
        </div>
        <div class="hidden md:block w-72 h-72 lg:w-96 lg:h-96 shrink-0 relative">
          <canvas id="spirograph" class="w-full h-full"></canvas>
        </div>
      </div>
    </div>
    <div class="relative h-12 md:h-20">
      <svg class="absolute bottom-0 w-full h-full" viewBox="0 0 1440 80" fill="none" preserveAspectRatio="none">
        <path d="M0 80L720 40L1440 80H0Z" fill="#f8fafc"/>
      </svg>
    </div>
  </section>

  <!-- Intro -->
  <section class="section-padding">
    <div class="container-narrow mx-auto">
      <div class="max-w-3xl">
        <div class="space-y-4 text-slate-600 leading-relaxed text-lg">
          <p>
            In elke organisatie is er werk dat mensen energie geeft en werk dat energie kost. Gesprekken met klanten, creatieve oplossingen bedenken, een lastig probleem tot op de bodem uitzoeken &mdash; dat is waardevol werk.
          </p>
          <p>
            En dan is er het andere werk. Gegevens overtikken van het ene systeem naar het andere. Handmatig controleren of alles klopt. Dezelfde e-mail voor de derde keer die week versturen. Dat soort taken zijn niet alleen saai &mdash; ze zijn ook foutgevoelig. En ze houden mensen af van het werk dat er echt toe doet.
          </p>
          <p>
            Wij helpen organisaties om dat tweede type werk door een computer te laten doen. Goed, betrouwbaar, en zonder dat iemand er nog naar hoeft om te kijken.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section-padding bg-slate-100/50">
    <div class="container-narrow mx-auto">
      <h2 class="heading-lg text-navy-900 mb-12">Drie manieren waarop wij helpen</h2>

      <div class="space-y-8">
        <!-- Service 1: Software op maat -->
        <div class="card p-8 animate-on-scroll">
          <div class="flex items-start gap-5">
            <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center shrink-0 mt-1">
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            </div>
            <div>
              <h3 class="heading-sm text-navy-900 mb-3">Software bouwen</h3>
              <div class="space-y-3 text-slate-600 leading-relaxed">
                <p>
                  Soms bestaat de software die u nodig heeft gewoon niet. Of het bestaat wel, maar het past niet bij hoe uw organisatie werkt. Dan bouwen wij het.
                </p>
                <p>
                  Wij beginnen klein &mdash; met een werkend prototype dat u kunt gebruiken &mdash; en bouwen van daaruit verder. U ziet snel of het de goede kant opgaat, en wij leren snel wat er echt nodig is.
                </p>
                <p class="text-sm text-slate-500">
                  Voorbeelden: <a href="/projecten/#brede-school" class="text-accent hover:underline">Brede School Zuidoost</a> (registratieplatform, honderden inschrijvingen per periode), <a href="/projecten/formbridge/" class="text-accent hover:underline">FormBridge</a> (formulieren-backend, duizenden inzendingen per maand).
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Service 2: Automatisering -->
        <div class="card p-8 animate-on-scroll delay-1">
          <div class="flex items-start gap-5">
            <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center shrink-0 mt-1">
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
            </div>
            <div>
              <h3 class="heading-sm text-navy-900 mb-3">Automatiseren</h3>
              <div class="space-y-3 text-slate-600 leading-relaxed">
                <p>
                  Veel organisaties besteden uren per week aan werk dat een computer beter en sneller kan. Niet omdat ze het niet weten, maar omdat niemand de tijd heeft om het aan te pakken.
                </p>
                <p>
                  Wij kijken samen naar welke taken zich lenen voor automatisering. Dat kan iets kleins zijn &mdash; een rapportage die zichzelf samenstelt &mdash; of iets groters, zoals een AI-chatbot die klantvragen beantwoordt op basis van uw eigen documentatie.
                </p>
                <p class="text-sm text-slate-500">
                  Voorbeeld: <a href="/projecten/#chatbot" class="text-accent hover:underline">AI Chatbot</a> (maakt kennisbanken doorzoekbaar via natuurlijke taal, beantwoordt klantvragen 24/7).
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Service 3: Beheer & onderhoud -->
        <div class="card p-8 animate-on-scroll delay-2">
          <div class="flex items-start gap-5">
            <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center shrink-0 mt-1">
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div>
              <h3 class="heading-sm text-navy-900 mb-3">Beheren en onderhouden</h3>
              <div class="space-y-3 text-slate-600 leading-relaxed">
                <p>
                  Software die draait moet ook blijven draaien. Wij zorgen voor updates, monitoring en aanpassingen wanneer dat nodig is. Zonder dat u zich er druk over hoeft te maken.
                </p>
                <p>
                  Dit geldt zowel voor software die wij gebouwd hebben als voor bestaande systemen die u al in gebruik heeft. U heeft &eacute;&eacute;n aanspreekpunt, en dat is ook degene die het werk doet.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How we work -->
  <section class="section-padding">
    <div class="container-narrow mx-auto">
      <div class="max-w-3xl">
        <h2 class="heading-lg text-navy-900 mb-6">Hoe dat er in de praktijk uitziet</h2>
        <div class="space-y-4 text-slate-600 leading-relaxed text-lg">
          <p>
            Wij werken met een klein team. Dat betekent: u praat met de mensen die ook daadwerkelijk bouwen. Geen tussenschakels, geen stille post, geen weken wachten op een offerte.
          </p>
          <p>
            Een eerste gesprek kost u niets en verplicht u tot niets. Wij luisteren naar uw situatie, stellen vragen, en geven eerlijk aan of wij de juiste partij zijn. Soms is het antwoord: dit kunt u beter zelf oplossen, en dan vertellen wij u hoe.
          </p>
        </div>
      </div>
    </div>
  </section>

  <CTA
    heading="Benieuwd of wij iets voor u kunnen betekenen?"
    subtitle="Een kort gesprek is vaak genoeg om te weten of het past. Geen verplichtingen."
  />
</Layout>

<script>
  const canvas = document.getElementById('spirograph') as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;

    function resize() {
      canvas.width = canvas.offsetWidth * 2;
      canvas.height = canvas.offsetHeight * 2;
      ctx.scale(2, 2);
    }
    resize();

    const patterns = [
      { R: 200, r: 80, d: 60 },
      { R: 200, r: 130, d: 75 },
      { R: 200, r: 55, d: 50 },
      { R: 200, r: 105, d: 90 },
      { R: 200, r: 70, d: 45 },
      { R: 200, r: 95, d: 80 },
    ];

    let patternIndex = 0;
    let t = 0;
    let fadeAlpha = 1;
    let phase: 'drawing' | 'fading' | 'waiting' = 'drawing';
    let waitFrames = 0;
    let points: { x: number; y: number }[] = [];

    function gcd(a: number, b: number): number {
      a = Math.abs(Math.round(a));
      b = Math.abs(Math.round(b));
      while (b) { [a, b] = [b, a % b]; }
      return a;
    }

    function getMaxT(R: number, r: number): number {
      return (r / gcd(R, r)) * 2 * Math.PI;
    }

    function draw() {
      const w = canvas.offsetWidth;
      const h = canvas.offsetHeight;
      ctx.clearRect(0, 0, w, h);

      const cx = w / 2;
      const cy = h / 2;
      const p = patterns[patternIndex];
      const scale = Math.min(w, h) / 600;
      const R = p.R * scale;
      const r = p.r * scale;
      const d = p.d * scale;
      const maxT = getMaxT(p.R, p.r);

      if (phase === 'drawing') {
        for (let i = 0; i < 2; i++) {
          if (t <= maxT + 0.1) {
            const x = cx + (R - r) * Math.cos(t) + d * Math.cos(((R - r) / r) * t);
            const y = cy + (R - r) * Math.sin(t) - d * Math.sin(((R - r) / r) * t);
            points.push({ x, y });
            t += 0.04;
          }
        }
        if (t > maxT + 0.1) { phase = 'fading'; fadeAlpha = 1; }
      }

      if (phase === 'fading') {
        fadeAlpha -= 0.008;
        if (fadeAlpha <= 0) { phase = 'waiting'; waitFrames = 30; }
      }

      if (phase === 'waiting') {
        waitFrames--;
        if (waitFrames <= 0) {
          patternIndex = (patternIndex + 1) % patterns.length;
          t = 0; points = []; fadeAlpha = 1; phase = 'drawing';
        }
      }

      if (points.length > 1) {
        const alpha = phase === 'fading' ? fadeAlpha : 1;
        for (let i = 1; i < points.length; i++) {
          const segAlpha = (i / points.length) * 0.8 * alpha;
          ctx.beginPath();
          ctx.moveTo(points[i - 1].x, points[i - 1].y);
          ctx.lineTo(points[i].x, points[i].y);
          ctx.strokeStyle = `rgba(59, 130, 246, ${segAlpha})`;
          ctx.lineWidth = 1.5;
          ctx.stroke();
        }
        if (phase === 'drawing' && points.length > 0) {
          const last = points[points.length - 1];
          ctx.beginPath();
          ctx.arc(last.x, last.y, 3, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(251, 191, 36, 0.9)';
          ctx.fill();
        }
      }

      requestAnimationFrame(draw);
    }

    draw();
  }
</script>
