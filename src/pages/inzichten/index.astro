---
import Layout from '../../layouts/Layout.astro';

const articles = [
  {
    title: 'Waarom de wereld maakbaar is',
    date: '2026-03-09',
    excerpt: 'Alles om ons heen is door mensen gemaakt. Software, organisaties, processen — het kan allemaal opnieuw worden ontworpen. Waarom wij bij Perceptum geloven in bouwen boven plannen.',
    slug: 'de-wereld-is-maakbaar',
    readingTime: '3 min',
  },
];
---

<Layout
  title="Inzichten"
  description="Artikelen en inzichten van Perceptum over digitale strategie, software en technologie."
>
  <section class="gradient-navy relative overflow-hidden -mt-20 pt-20">
    <!-- Flowing wave / signal animation -->
    <div class="absolute inset-0 overflow-hidden">
      <svg class="absolute bottom-0 left-0 w-full h-full" viewBox="0 0 1200 400" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
        <!-- Wave 1 -->
        <path d="M0,200 Q150,120 300,200 T600,200 T900,200 T1200,200" stroke="rgba(59,130,246,0.15)" stroke-width="2" fill="none">
          <animate attributeName="d"
            values="M0,200 Q150,120 300,200 T600,200 T900,200 T1200,200;M0,200 Q150,280 300,200 T600,200 T900,200 T1200,200;M0,200 Q150,120 300,200 T600,200 T900,200 T1200,200"
            dur="8s" repeatCount="indefinite"/>
        </path>
        <!-- Wave 2 -->
        <path d="M0,220 Q200,160 400,220 T800,220 T1200,220" stroke="rgba(251,191,36,0.12)" stroke-width="1.5" fill="none">
          <animate attributeName="d"
            values="M0,220 Q200,160 400,220 T800,220 T1200,220;M0,220 Q200,280 400,220 T800,220 T1200,220;M0,220 Q200,160 400,220 T800,220 T1200,220"
            dur="6s" repeatCount="indefinite"/>
        </path>
        <!-- Wave 3 -->
        <path d="M0,240 Q100,180 200,240 T400,240 T600,240 T800,240 T1000,240 T1200,240" stroke="rgba(59,130,246,0.1)" stroke-width="1" fill="none">
          <animate attributeName="d"
            values="M0,240 Q100,180 200,240 T400,240 T600,240 T800,240 T1000,240 T1200,240;M0,240 Q100,300 200,240 T400,240 T600,240 T800,240 T1000,240 T1200,240;M0,240 Q100,180 200,240 T400,240 T600,240 T800,240 T1000,240 T1200,240"
            dur="10s" repeatCount="indefinite"/>
        </path>

        <!-- Signal dots traveling along waves -->
        <circle r="3" fill="rgba(59,130,246,0.6)">
          <animateMotion dur="5s" repeatCount="indefinite" path="M0,200 Q150,120 300,200 Q450,280 600,200 Q750,120 900,200 Q1050,280 1200,200"/>
        </circle>
        <circle r="2.5" fill="rgba(251,191,36,0.5)">
          <animateMotion dur="7s" repeatCount="indefinite" path="M0,220 Q200,160 400,220 Q600,280 800,220 Q1000,160 1200,220"/>
        </circle>
        <circle r="2" fill="rgba(203,213,225,0.4)">
          <animateMotion dur="9s" repeatCount="indefinite" path="M0,240 Q100,180 200,240 Q300,300 400,240 Q500,180 600,240 Q700,300 800,240 Q900,180 1000,240 Q1100,300 1200,240"/>
        </circle>
      </svg>
    </div>
    <div class="container-narrow mx-auto px-6 py-24 md:py-32 relative z-10">
      <p class="text-accent font-medium text-sm tracking-wide uppercase mb-4">Inzichten</p>
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white tracking-tight leading-[1.08] max-w-3xl">
        Wat wij leren,<br />delen wij.
      </h1>
    </div>
    <div class="relative h-12 md:h-20">
      <svg class="absolute bottom-0 w-full h-full" viewBox="0 0 1440 80" fill="none" preserveAspectRatio="none">
        <path d="M0 80L720 40L1440 80H0Z" fill="#f8fafc"/>
      </svg>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-narrow mx-auto">
      <div class="space-y-8">
        {articles.map((article) => (
          <a href={`/inzichten/${article.slug}/`} class="block group">
            <article class="card p-8 animate-on-scroll">
              <div class="flex items-center gap-3 text-xs text-slate-400 mb-3">
                <time datetime={article.date}>{new Date(article.date).toLocaleDateString('nl-NL', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
                <span>&middot;</span>
                <span>{article.readingTime}</span>
              </div>
              <h2 class="heading-sm text-navy-900 group-hover:text-accent transition-colors mb-3">{article.title}</h2>
              <p class="text-slate-500 leading-relaxed">{article.excerpt}</p>
              <span class="inline-flex items-center gap-1 text-sm font-medium text-accent mt-4">
                Lees verder
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </span>
            </article>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
