---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Rubik's Cube" description="Een Rubik's kubus die zichzelf scrambled en vervolgens stap voor stap oplost.">
  <section class="gradient-navy relative overflow-hidden -mt-20 pt-20 min-h-[80vh] flex flex-col">
    <div class="absolute inset-0 overflow-hidden">
      <canvas id="animation" class="absolute inset-0 w-full h-full"></canvas>
    </div>
    <div class="container-narrow mx-auto px-6 pt-24 pb-8 relative z-10">
      <a href="/animaties/" class="text-slate-400 text-sm hover:text-accent transition-colors">&larr; Animaties</a>
      <h1 class="heading-xl text-white mt-4">Rubik's Cube</h1>
      <p class="text-slate-300 mt-2 max-w-xl">Scramble &rarr; solve. 43 quintillion mogelijke toestanden, &eacute;&eacute;n oplossing.</p>
    </div>
    <div class="relative h-12 md:h-20 mt-auto">
      <svg class="absolute bottom-0 w-full h-full" viewBox="0 0 1440 80" fill="none" preserveAspectRatio="none">
        <path d="M0 80L720 40L1440 80H0Z" fill="#f8fafc"/>
      </svg>
    </div>
  </section>
</Layout>

<script>
  const canvas = document.getElementById('animation') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  function resize() {
    const parent = canvas.parentElement!;
    canvas.width = parent.clientWidth;
    canvas.height = parent.clientHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  // ═══════════════════════════════════════════════════════════════
  // Types & math
  // ═══════════════════════════════════════════════════════════════
  type V3 = [number, number, number];

  function v3add(a: V3, b: V3): V3 { return [a[0]+b[0], a[1]+b[1], a[2]+b[2]]; }
  function v3sub(a: V3, b: V3): V3 { return [a[0]-b[0], a[1]-b[1], a[2]-b[2]]; }
  function v3cross(a: V3, b: V3): V3 {
    return [a[1]*b[2]-a[2]*b[1], a[2]*b[0]-a[0]*b[2], a[0]*b[1]-a[1]*b[0]];
  }
  function v3dot(a: V3, b: V3): number { return a[0]*b[0]+a[1]*b[1]+a[2]*b[2]; }
  function v3len(a: V3): number { return Math.sqrt(v3dot(a,a)); }
  function v3normalize(a: V3): V3 { const l=v3len(a); return l>0?[a[0]/l,a[1]/l,a[2]/l]:[0,0,0]; }

  function rotateY(p: V3, a: number): V3 {
    const c=Math.cos(a), s=Math.sin(a);
    return [p[0]*c+p[2]*s, p[1], -p[0]*s+p[2]*c];
  }
  function rotateX(p: V3, a: number): V3 {
    const c=Math.cos(a), s=Math.sin(a);
    return [p[0], p[1]*c-p[2]*s, p[1]*s+p[2]*c];
  }
  function rotateAroundAxis(p: V3, axis: V3, angle: number): V3 {
    const [ux,uy,uz]=axis, c=Math.cos(angle), s=Math.sin(angle), [x,y,z]=p;
    return [
      (c+ux*ux*(1-c))*x+(ux*uy*(1-c)-uz*s)*y+(ux*uz*(1-c)+uy*s)*z,
      (uy*ux*(1-c)+uz*s)*x+(c+uy*uy*(1-c))*y+(uy*uz*(1-c)-ux*s)*z,
      (uz*ux*(1-c)-uy*s)*x+(uz*uy*(1-c)+ux*s)*y+(c+uz*uz*(1-c))*z,
    ];
  }

  // Perspective projection
  const FOCAL = 7;
  function project(p: V3, cx: number, cy: number, scale: number): [number, number] {
    const d = FOCAL / (FOCAL + p[2]);
    return [cx + p[0]*scale*d, cy - p[1]*scale*d];
  }

  // Cubic ease in-out
  function easeInOutCubic(t: number): number {
    return t < 0.5 ? 4*t*t*t : 1 - Math.pow(-2*t+2, 3)/2;
  }

  // ═══════════════════════════════════════════════════════════════
  // Cube state (logical) — 6 faces × 9 stickers
  // Face indices: U=0 D=1 F=2 B=3 L=4 R=5
  // ═══════════════════════════════════════════════════════════════
  const U=0,D=1,F=2,B=3,L=4,R=5;
  type CubeState = string[][];

  // Realistic Rubik's cube colors
  const FACE_COLORS: Record<string, string> = {
    W: '#ffffff', Y: '#ffd500', R: '#b71234',
    O: '#ff5800', B: '#0046ad', G: '#009b48',
  };
  const PLASTIC = '#111111';

  function solvedCube(): CubeState {
    return [
      Array(9).fill('W'), Array(9).fill('Y'),
      Array(9).fill('R'), Array(9).fill('O'),
      Array(9).fill('G'), Array(9).fill('B'),
    ];
  }

  function rotateFaceCW(face: string[]): string[] {
    return [face[6],face[3],face[0],face[7],face[4],face[1],face[8],face[5],face[2]];
  }

  function applyMoveCW(c: CubeState, f: string): void {
    switch (f) {
      case 'U': {
        c[U]=rotateFaceCW(c[U]);
        const t=[c[F][0],c[F][1],c[F][2]];
        [c[F][0],c[F][1],c[F][2]]=[c[R][0],c[R][1],c[R][2]];
        [c[R][0],c[R][1],c[R][2]]=[c[B][0],c[B][1],c[B][2]];
        [c[B][0],c[B][1],c[B][2]]=[c[L][0],c[L][1],c[L][2]];
        [c[L][0],c[L][1],c[L][2]]=t; break;
      }
      case 'D': {
        c[D]=rotateFaceCW(c[D]);
        const t=[c[F][6],c[F][7],c[F][8]];
        [c[F][6],c[F][7],c[F][8]]=[c[L][6],c[L][7],c[L][8]];
        [c[L][6],c[L][7],c[L][8]]=[c[B][6],c[B][7],c[B][8]];
        [c[B][6],c[B][7],c[B][8]]=[c[R][6],c[R][7],c[R][8]];
        [c[R][6],c[R][7],c[R][8]]=t; break;
      }
      case 'F': {
        c[F]=rotateFaceCW(c[F]);
        const t=[c[U][6],c[U][7],c[U][8]];
        [c[U][6],c[U][7],c[U][8]]=[c[L][8],c[L][5],c[L][2]];
        [c[L][2],c[L][5],c[L][8]]=[c[D][0],c[D][1],c[D][2]];
        [c[D][0],c[D][1],c[D][2]]=[c[R][6],c[R][3],c[R][0]];
        [c[R][0],c[R][3],c[R][6]]=t; break;
      }
      case 'B': {
        c[B]=rotateFaceCW(c[B]);
        const t=[c[U][0],c[U][1],c[U][2]];
        [c[U][0],c[U][1],c[U][2]]=[c[R][2],c[R][5],c[R][8]];
        [c[R][2],c[R][5],c[R][8]]=[c[D][8],c[D][7],c[D][6]];
        [c[D][6],c[D][7],c[D][8]]=[c[L][0],c[L][3],c[L][6]];
        [c[L][0],c[L][3],c[L][6]]=[t[2],t[1],t[0]]; break;
      }
      case 'L': {
        c[L]=rotateFaceCW(c[L]);
        const t=[c[U][0],c[U][3],c[U][6]];
        [c[U][0],c[U][3],c[U][6]]=[c[B][8],c[B][5],c[B][2]];
        [c[B][2],c[B][5],c[B][8]]=[c[D][6],c[D][3],c[D][0]];
        [c[D][0],c[D][3],c[D][6]]=[c[F][0],c[F][3],c[F][6]];
        [c[F][0],c[F][3],c[F][6]]=t; break;
      }
      case 'R': {
        c[R]=rotateFaceCW(c[R]);
        const t=[c[U][2],c[U][5],c[U][8]];
        [c[U][2],c[U][5],c[U][8]]=[c[F][2],c[F][5],c[F][8]];
        [c[F][2],c[F][5],c[F][8]]=[c[D][2],c[D][5],c[D][8]];
        [c[D][2],c[D][5],c[D][8]]=[c[B][6],c[B][3],c[B][0]];
        [c[B][0],c[B][3],c[B][6]]=t; break;
      }
    }
  }

  function applyMove(c: CubeState, move: string): void {
    const base = move.replace("'","");
    const times = move.endsWith("'") ? 3 : 1;
    for (let i=0; i<times; i++) applyMoveCW(c, base);
  }

  function inverseMove(m: string): string {
    return m.endsWith("'") ? m.slice(0,-1) : m+"'";
  }

  // ═══════════════════════════════════════════════════════════════
  // 3D Cubie model — 26 cubies, each with up to 6 faces
  // Uses snap-back technique: cubies stay at grid positions,
  // only animated during turns, then colors update from logical state.
  // ═══════════════════════════════════════════════════════════════
  const CUBIE_SIZE = 0.44;  // half-width of each cubie (grid spacing = 1.0)
  const STICKER_INSET = 0.06; // sticker is inset from cubie edge
  const STICKER_RADIUS = 0.08; // corner radius for rounded stickers
  const GAP = 1 - CUBIE_SIZE * 2; // visible gap between cubies

  interface CubieFace {
    // 4 corners of the outer cubie face (black plastic)
    outerCorners: V3[];
    // 4 corners of the inset sticker
    stickerCorners: V3[];
    // outward normal
    normal: V3;
    // which logical face & sticker index this maps to (null for hidden faces)
    logicalFace: number | null;
    logicalSticker: number | null;
  }

  interface Cubie {
    // grid position (-1, 0, or 1 on each axis)
    gx: number; gy: number; gz: number;
    faces: CubieFace[];
  }

  // Map a cubie's outward-facing surfaces to logical face/sticker indices
  function getLogicalMapping(gx: number, gy: number, gz: number, normalAxis: string):
    { face: number; sticker: number } | null {
    // Which logical face does this normal point to?
    // +Y → U, -Y → D, +Z → F, -Z → B, -X → L, +X → R
    let faceIdx: number;
    if (normalAxis === '+y') faceIdx = U;
    else if (normalAxis === '-y') faceIdx = D;
    else if (normalAxis === '+z') faceIdx = F;
    else if (normalAxis === '-z') faceIdx = B;
    else if (normalAxis === '-x') faceIdx = L;
    else if (normalAxis === '+x') faceIdx = R;
    else return null;

    // Only outer faces have stickers
    if (faceIdx === U && gy !== 1) return null;
    if (faceIdx === D && gy !== -1) return null;
    if (faceIdx === F && gz !== 1) return null;
    if (faceIdx === B && gz !== -1) return null;
    if (faceIdx === L && gx !== -1) return null;
    if (faceIdx === R && gx !== 1) return null;

    // Sticker index (row-major 0-8) depends on the face
    let row: number, col: number;
    switch (faceIdx) {
      case U: row = 1-gz; col = gx+1; break;       // top-down: -z is row 0
      case D: row = gz+1; col = gx+1; break;
      case F: row = 1-gy; col = gx+1; break;        // top-down: +y is row 0
      case B: row = 1-gy; col = 1-gx; break;        // mirrored
      case L: row = 1-gy; col = 1-gz; break;
      case R: row = 1-gy; col = gz+1; break;
      default: return null;
    }
    return { face: faceIdx, sticker: row*3+col };
  }

  function buildCubies(): Cubie[] {
    const cubies: Cubie[] = [];
    const s = CUBIE_SIZE;
    const si = CUBIE_SIZE - STICKER_INSET; // sticker half-size

    for (let gx = -1; gx <= 1; gx++) {
      for (let gy = -1; gy <= 1; gy++) {
        for (let gz = -1; gz <= 1; gz++) {
          // Skip the invisible center cubie
          if (gx === 0 && gy === 0 && gz === 0) continue;

          const cx = gx, cy = gy, cz = gz; // center of cubie in world
          const faces: CubieFace[] = [];

          // 6 faces of this cubie
          const faceDefs: { normal: V3; normalAxis: string; corners: V3[]; sCorners: V3[] }[] = [
            { normal: [0,1,0], normalAxis: '+y',
              corners: [[cx-s,cy+s,cz-s],[cx+s,cy+s,cz-s],[cx+s,cy+s,cz+s],[cx-s,cy+s,cz+s]],
              sCorners: [[cx-si,cy+s+0.001,cz-si],[cx+si,cy+s+0.001,cz-si],[cx+si,cy+s+0.001,cz+si],[cx-si,cy+s+0.001,cz+si]] },
            { normal: [0,-1,0], normalAxis: '-y',
              corners: [[cx-s,cy-s,cz+s],[cx+s,cy-s,cz+s],[cx+s,cy-s,cz-s],[cx-s,cy-s,cz-s]],
              sCorners: [[cx-si,cy-s-0.001,cz+si],[cx+si,cy-s-0.001,cz+si],[cx+si,cy-s-0.001,cz-si],[cx-si,cy-s-0.001,cz-si]] },
            { normal: [0,0,1], normalAxis: '+z',
              corners: [[cx-s,cy-s,cz+s],[cx+s,cy-s,cz+s],[cx+s,cy+s,cz+s],[cx-s,cy+s,cz+s]],
              sCorners: [[cx-si,cy-si,cz+s+0.001],[cx+si,cy-si,cz+s+0.001],[cx+si,cy+si,cz+s+0.001],[cx-si,cy+si,cz+s+0.001]] },
            { normal: [0,0,-1], normalAxis: '-z',
              corners: [[cx+s,cy-s,cz-s],[cx-s,cy-s,cz-s],[cx-s,cy+s,cz-s],[cx+s,cy+s,cz-s]],
              sCorners: [[cx+si,cy-si,cz-s-0.001],[cx-si,cy-si,cz-s-0.001],[cx-si,cy+si,cz-s-0.001],[cx+si,cy+si,cz-s-0.001]] },
            { normal: [-1,0,0], normalAxis: '-x',
              corners: [[cx-s,cy-s,cz-s],[cx-s,cy-s,cz+s],[cx-s,cy+s,cz+s],[cx-s,cy+s,cz-s]],
              sCorners: [[cx-s-0.001,cy-si,cz-si],[cx-s-0.001,cy-si,cz+si],[cx-s-0.001,cy+si,cz+si],[cx-s-0.001,cy+si,cz-si]] },
            { normal: [1,0,0], normalAxis: '+x',
              corners: [[cx+s,cy-s,cz+s],[cx+s,cy-s,cz-s],[cx+s,cy+s,cz-s],[cx+s,cy+s,cz+s]],
              sCorners: [[cx+s+0.001,cy-si,cz+si],[cx+s+0.001,cy-si,cz-si],[cx+s+0.001,cy+si,cz-si],[cx+s+0.001,cy+si,cz+si]] },
          ];

          for (const fd of faceDefs) {
            const mapping = getLogicalMapping(gx, gy, gz, fd.normalAxis);
            faces.push({
              outerCorners: fd.corners,
              stickerCorners: fd.sCorners,
              normal: fd.normal,
              logicalFace: mapping?.face ?? null,
              logicalSticker: mapping?.sticker ?? null,
            });
          }
          cubies.push({ gx, gy, gz, faces });
        }
      }
    }
    return cubies;
  }

  // Which cubies are affected by a face turn?
  function getCubiesInLayer(cubies: Cubie[], move: string): Set<number> {
    const base = move.replace("'","");
    const indices = new Set<number>();
    cubies.forEach((c, i) => {
      switch (base) {
        case 'U': if (c.gy === 1) indices.add(i); break;
        case 'D': if (c.gy === -1) indices.add(i); break;
        case 'F': if (c.gz === 1) indices.add(i); break;
        case 'B': if (c.gz === -1) indices.add(i); break;
        case 'L': if (c.gx === -1) indices.add(i); break;
        case 'R': if (c.gx === 1) indices.add(i); break;
      }
    });
    return indices;
  }

  function getMoveAxis(move: string): { axis: V3; direction: number } {
    const base = move.replace("'","");
    const dir = move.endsWith("'") ? 1 : -1;
    switch (base) {
      case 'U': return { axis: [0,1,0], direction: dir };
      case 'D': return { axis: [0,1,0], direction: -dir };
      case 'F': return { axis: [0,0,1], direction: dir };
      case 'B': return { axis: [0,0,1], direction: -dir };
      case 'R': return { axis: [1,0,0], direction: dir };
      case 'L': return { axis: [1,0,0], direction: -dir };
      default: return { axis: [0,1,0], direction: 1 };
    }
  }

  // ═══════════════════════════════════════════════════════════════
  // Lighting
  // ═══════════════════════════════════════════════════════════════
  const LIGHT_DIR: V3 = v3normalize([0.4, 0.8, 0.6]); // from upper-right-front
  const AMBIENT = 0.45;
  const DIFFUSE = 0.55;

  function shadedColor(baseHex: string, normal: V3, camYaw: number, camPitch: number): string {
    // Transform normal by camera rotation to get screen-space normal
    let n: V3 = rotateY(normal, camYaw);
    n = rotateX(n, camPitch);
    // Light in view space
    const ndotl = Math.max(0, v3dot(n, LIGHT_DIR));
    const brightness = AMBIENT + DIFFUSE * ndotl;

    // Parse hex
    const r = parseInt(baseHex.slice(1,3),16);
    const g = parseInt(baseHex.slice(3,5),16);
    const b = parseInt(baseHex.slice(5,7),16);

    const sr = Math.min(255, Math.round(r * brightness));
    const sg = Math.min(255, Math.round(g * brightness));
    const sb = Math.min(255, Math.round(b * brightness));

    return `rgb(${sr},${sg},${sb})`;
  }

  // ═══════════════════════════════════════════════════════════════
  // Rendering
  // ═══════════════════════════════════════════════════════════════
  interface RenderQuad {
    projected: [number, number][];
    depth: number;
    fillColor: string;
    isSticker: boolean;
  }

  function drawRoundedQuad(pts: [number,number][], color: string, isSticker: boolean) {
    ctx.fillStyle = color;
    if (!isSticker) {
      // Black plastic: sharp edges
      ctx.beginPath();
      ctx.moveTo(pts[0][0], pts[0][1]);
      for (let i=1; i<pts.length; i++) ctx.lineTo(pts[i][0], pts[i][1]);
      ctx.closePath();
      ctx.fill();
      return;
    }

    // Sticker: rounded corners via subdivision
    // Inset each corner slightly toward center and use quadratic curves
    const cx = (pts[0][0]+pts[1][0]+pts[2][0]+pts[3][0])/4;
    const cy = (pts[0][1]+pts[1][1]+pts[2][1]+pts[3][1])/4;

    // Compute edge lengths to determine corner radius in screen space
    const edgeLen = Math.sqrt(
      Math.pow(pts[1][0]-pts[0][0],2) + Math.pow(pts[1][1]-pts[0][1],2)
    );
    const r = Math.max(2, edgeLen * 0.12); // 12% of edge = corner radius

    ctx.beginPath();
    for (let i=0; i<4; i++) {
      const curr = pts[i];
      const next = pts[(i+1)%4];
      const prev = pts[(i+3)%4];

      // Direction vectors from corner to adjacent corners
      const dnx = next[0]-curr[0], dny = next[1]-curr[1];
      const dpx = prev[0]-curr[0], dpy = prev[1]-curr[1];
      const dnd = Math.sqrt(dnx*dnx+dny*dny) || 1;
      const dpd = Math.sqrt(dpx*dpx+dpy*dpy) || 1;

      // Points offset from corner along each edge
      const rn = Math.min(r, dnd*0.4);
      const rp = Math.min(r, dpd*0.4);
      const pnx = curr[0]+dnx/dnd*rn, pny = curr[1]+dny/dnd*rn;
      const ppx = curr[0]+dpx/dpd*rp, ppy = curr[1]+dpy/dpd*rp;

      if (i === 0) {
        ctx.moveTo(ppx, ppy);
      } else {
        ctx.lineTo(ppx, ppy);
      }
      ctx.quadraticCurveTo(curr[0], curr[1], pnx, pny);
    }
    ctx.closePath();
    ctx.fill();

    // Subtle glossy highlight on sticker
    const grad = ctx.createLinearGradient(
      pts[0][0], pts[0][1], pts[2][0], pts[2][1]
    );
    grad.addColorStop(0, 'rgba(255,255,255,0.18)');
    grad.addColorStop(0.5, 'rgba(255,255,255,0)');
    grad.addColorStop(1, 'rgba(0,0,0,0.08)');
    ctx.fillStyle = grad;
    ctx.fill();
  }

  // ═══════════════════════════════════════════════════════════════
  // Animation state
  // ═══════════════════════════════════════════════════════════════
  let cube = solvedCube();
  const cubies = buildCubies();

  const MOVE_NAMES = ['U',"U'",'D',"D'",'F',"F'",'B',"B'",'L',"L'",'R',"R'"];
  const SCRAMBLE_COUNT = 20;
  const SCRAMBLE_DURATION = 200;  // ms per move when scrambling
  const SOLVE_DURATION = 500;     // ms per move when solving

  type Phase = 'scrambling' | 'pausing' | 'solving' | 'celebrating';
  let phase: Phase = 'scrambling';
  let moveQueue: string[] = [];
  let currentMoveIdx = 0;

  // Current animation
  let animMove: string | null = null;
  let animStart = 0;
  let animDuration = SCRAMBLE_DURATION;
  let animLayerIndices = new Set<number>();
  let animAxis: V3 = [0,1,0];
  let animDirection = 1;

  // Camera
  let camYaw = -0.55;
  let camPitch = 0.50;

  function generateScramble(): string[] {
    const moves: string[] = [];
    let lastBase = '';
    for (let i=0; i<SCRAMBLE_COUNT; i++) {
      let m: string;
      do {
        m = MOVE_NAMES[Math.floor(Math.random()*MOVE_NAMES.length)];
      } while (m.replace("'","") === lastBase);
      moves.push(m);
      lastBase = m.replace("'","");
    }
    return moves;
  }

  function startRound() {
    cube = solvedCube();
    const scramble = generateScramble();
    const solve = scramble.map(inverseMove).reverse();
    moveQueue = [...scramble];
    currentMoveIdx = 0;
    phase = 'scrambling';
    animDuration = SCRAMBLE_DURATION;
    startNextMove();
  }

  function startNextMove() {
    if (currentMoveIdx >= moveQueue.length) {
      if (phase === 'scrambling') {
        phase = 'pausing';
        animMove = null;
        // Build solve queue from current scramble
        const scramble = moveQueue;
        setTimeout(() => {
          phase = 'solving';
          moveQueue = scramble.map(inverseMove).reverse();
          currentMoveIdx = 0;
          animDuration = SOLVE_DURATION;
          startNextMove();
        }, 800);
      } else if (phase === 'solving') {
        phase = 'celebrating';
        animMove = null;
        setTimeout(startRound, 3500);
      }
      return;
    }

    const move = moveQueue[currentMoveIdx];
    animMove = move;
    animStart = performance.now();
    animLayerIndices = getCubiesInLayer(cubies, move);
    const ma = getMoveAxis(move);
    animAxis = ma.axis;
    animDirection = ma.direction;
  }

  function updateAnimation(now: number) {
    if (!animMove) return;
    const elapsed = now - animStart;
    if (elapsed >= animDuration) {
      // Apply move to logical state, snap back
      applyMove(cube, animMove);
      animMove = null;
      currentMoveIdx++;
      startNextMove();
    }
  }

  // ═══════════════════════════════════════════════════════════════
  // Main draw loop
  // ═══════════════════════════════════════════════════════════════
  function draw(now: number) {
    const w = canvas.width, h = canvas.height;
    ctx.clearRect(0, 0, w, h);

    updateAnimation(now);

    // Camera auto-rotation
    const rotSpeed = phase === 'celebrating' ? 0.012 : 0.002;
    camYaw += rotSpeed;

    const cx = w/2, cy = h*0.47;
    const scale = Math.min(w, h) * 0.145;

    // Compute animation angle
    let animAngle = 0;
    if (animMove) {
      const elapsed = now - animStart;
      const t = Math.min(1, elapsed / animDuration);
      animAngle = easeInOutCubic(t) * (Math.PI/2) * animDirection;
    }

    // Collect all renderable quads
    const quads: RenderQuad[] = [];

    for (let ci=0; ci<cubies.length; ci++) {
      const cubie = cubies[ci];
      const isAnimating = animMove && animLayerIndices.has(ci);

      for (const face of cubie.faces) {
        // Back-face culling: transform normal
        let n: V3 = [...face.normal];
        if (isAnimating) n = rotateAroundAxis(n, animAxis, animAngle);
        let nView = rotateY(n, camYaw);
        nView = rotateX(nView, camPitch);
        // Cull faces pointing away from camera (z > 0 means pointing away)
        if (nView[2] > 0.05) continue;

        // Transform outer corners (black plastic face)
        const transformCorners = (corners: V3[]): V3[] => {
          return corners.map(p => {
            let pt: V3 = [...p];
            if (isAnimating) pt = rotateAroundAxis(pt, animAxis, animAngle);
            pt = rotateY(pt, camYaw);
            pt = rotateX(pt, camPitch);
            return pt;
          });
        };

        const outerT = transformCorners(face.outerCorners);
        const outerProj = outerT.map(p => project(p, cx, cy, scale)) as [number,number][];
        const outerDepth = outerT.reduce((s,p)=>s+p[2],0)/4;

        // Shaded black plastic
        const plasticColor = shadedColor(PLASTIC, face.normal, isAnimating ? 0 : 0, 0);
        // For the plastic, we compute lighting in model space for consistency
        let plasticN: V3 = [...face.normal];
        if (isAnimating) plasticN = rotateAroundAxis(plasticN, animAxis, animAngle);
        const plasticShaded = shadedColor(PLASTIC, plasticN, camYaw, camPitch);

        quads.push({
          projected: outerProj,
          depth: outerDepth,
          fillColor: plasticShaded,
          isSticker: false,
        });

        // If this face has a sticker, draw it on top
        if (face.logicalFace !== null && face.logicalSticker !== null) {
          const stickerT = transformCorners(face.stickerCorners);
          const stickerProj = stickerT.map(p => project(p, cx, cy, scale)) as [number,number][];
          const stickerDepth = stickerT.reduce((s,p)=>s+p[2],0)/4;

          const colorKey = cube[face.logicalFace][face.logicalSticker];
          let stickerN: V3 = [...face.normal];
          if (isAnimating) stickerN = rotateAroundAxis(stickerN, animAxis, animAngle);
          const stickerColor = shadedColor(FACE_COLORS[colorKey] || '#333', stickerN, camYaw, camPitch);

          quads.push({
            projected: stickerProj,
            depth: stickerDepth + 0.001, // slightly in front of plastic
            fillColor: stickerColor,
            isSticker: true,
          });
        }
      }
    }

    // Painter's algorithm: far to near
    quads.sort((a, b) => a.depth - b.depth);

    for (const q of quads) {
      drawRoundedQuad(q.projected, q.fillColor, q.isSticker);
    }

    // HUD
    const fontSize = Math.max(14, Math.min(w, h) * 0.025);
    ctx.textAlign = 'center';

    if (animMove) {
      const label = phase === 'scrambling' ? `Scramble: ${animMove}` : `Solve: ${animMove}`;
      ctx.font = `${fontSize}px "SF Mono", "Fira Code", monospace`;
      ctx.fillStyle = 'rgba(255,255,255,0.65)';
      ctx.fillText(label, cx, h * 0.87);
    }

    const phaseLabel: Record<Phase, string> = {
      scrambling: 'Scrambling...', pausing: 'Ready to solve',
      solving: 'Solving...', celebrating: 'Solved!',
    };
    ctx.font = `bold ${fontSize * 0.9}px "SF Mono", "Fira Code", monospace`;
    ctx.fillStyle = phase === 'celebrating' ? 'rgba(0,255,136,0.85)' : 'rgba(255,255,255,0.45)';
    ctx.fillText(phaseLabel[phase], cx, h * 0.91);

    if (phase === 'scrambling' || phase === 'solving') {
      const total = moveQueue.length;
      const current = Math.min(currentMoveIdx + 1, total);
      ctx.font = `${fontSize*0.7}px "SF Mono", "Fira Code", monospace`;
      ctx.fillStyle = 'rgba(255,255,255,0.35)';
      ctx.fillText(`Move ${current} / ${total}`, cx, h * 0.945);
    }

    requestAnimationFrame(draw);
  }

  startRound();
  requestAnimationFrame(draw);
</script>
