---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Rubik's Cube" description="Een Rubik's kubus die zichzelf scrambled en vervolgens stap voor stap oplost.">
  <section class="gradient-navy relative overflow-hidden -mt-20 pt-20 min-h-[80vh] flex flex-col">
    <div class="absolute inset-0 overflow-hidden flex items-center justify-center" id="cube-wrapper">
      <div id="cube-container"></div>
    </div>
    <div class="container-narrow mx-auto px-6 pt-24 pb-8 relative z-10">
      <a href="/animaties/" class="text-slate-400 text-sm hover:text-accent transition-colors">&larr; Animaties</a>
      <h1 class="heading-xl text-white mt-4">Rubik's Cube</h1>
      <p class="text-slate-300 mt-2 max-w-xl">Scramble &rarr; solve. 43 quintillion mogelijke toestanden, &eacute;&eacute;n oplossing.</p>
    </div>
    <div class="relative h-12 md:h-20 mt-auto">
      <svg class="absolute bottom-0 w-full h-full" viewBox="0 0 1440 80" fill="none" preserveAspectRatio="none">
        <path d="M0 80L720 40L1440 80H0Z" fill="#f8fafc"/>
      </svg>
    </div>
  </section>
</Layout>

<script src="/AnimCube3.js" is:inline></script>

<script is:inline>
  function initCube() {
    var wrapper = document.getElementById('cube-wrapper');
    var container = document.getElementById('cube-container');
    if (!wrapper || !container) return;

    var wrapperRect = wrapper.getBoundingClientRect();
    var size = Math.min(wrapperRect.width, wrapperRect.height) * 0.65;
    size = Math.max(200, Math.min(500, size));

    container.style.width = size + 'px';
    container.style.height = size + 'px';

    AnimCube3(
      'id=cube-container' +
      '&bgcolor=0f172a' +
      '&cubecolor=111111' +
      '&buttonbar=2' +
      '&position=lluu' +
      '&hint=0' +
      '&scale=0' +
      '&scramble=2' +
      '&speed=8' +
      '&borderwidth=10'
    );
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCube);
  } else {
    initCube();
  }
</script>
