---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact"
  description="Neem contact op met Perceptum. Bel 071 - 203 2103 of stuur een bericht via het contactformulier."
>
  <section class="gradient-navy relative overflow-hidden -mt-20 pt-20">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="container-narrow mx-auto px-6 py-20 md:py-28 relative z-10">
      <div class="flex items-center gap-8">
        <div class="flex-1">
          <h1 class="heading-xl text-white mb-6">Contact</h1>
          <p class="text-xl text-slate-300 max-w-2xl">
            U spreekt direct met Wijnand. Geen salesafdeling, geen wachtlijst.
          </p>
        </div>
        <div class="hidden md:block w-72 h-72 lg:w-96 lg:h-96 shrink-0 relative">
          <canvas id="geo-spirograph" class="w-full h-full"></canvas>
        </div>
      </div>
    </div>
    <div class="relative h-12 md:h-20">
      <svg class="absolute bottom-0 w-full h-full" viewBox="0 0 1440 80" fill="none" preserveAspectRatio="none">
        <path d="M0 80L720 40L1440 80H0Z" fill="#f8fafc"/>
      </svg>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-narrow mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">

        <!-- Contact Info -->
        <div class="lg:col-span-2">
          <h2 class="heading-md text-navy-900 mb-6">Direct contact</h2>

          <div class="space-y-6 mb-10">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-navy-900">Telefoon</p>
                <a href="tel:+31712032103" class="text-slate-500 hover:text-accent transition-colors">071 - 203 2103</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-navy-900">E-mail</p>
                <a href="mailto:wijnand@perceptum.nl" class="text-slate-500 hover:text-accent transition-colors">wijnand@perceptum.nl</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <p class="font-semibold text-navy-900">Locaties</p>
                <p class="text-slate-500">Noordwijk &middot; Amsterdam &middot; Leiden</p>
              </div>
            </div>
          </div>

          <div class="mt-8 p-5 rounded-xl bg-slate-50 border border-slate-200/60">
            <p class="text-sm text-slate-600 leading-relaxed">
              <span class="font-semibold text-navy-900">Wat kunt u verwachten?</span><br />
              Een reactie binnen 24 uur. Een kort kennismakingsgesprek zonder verplichtingen.
              Concrete feedback op uw vraagstuk, ongeacht of we gaan samenwerken.
            </p>
          </div>

          <div class="flex gap-3 mt-6">
            <a
              href="https://www.linkedin.com/in/wijnandbaretta/"
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-xl bg-slate-100 hover:bg-accent/10 flex items-center justify-center transition-colors"
              aria-label="LinkedIn"
            >
              <svg class="w-5 h-5 text-slate-500" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
            <a
              href="https://github.com/wijnandb"
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-xl bg-slate-100 hover:bg-accent/10 flex items-center justify-center transition-colors"
              aria-label="GitHub"
            >
              <svg class="w-5 h-5 text-slate-500" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="lg:col-span-3">
          <div class="card p-8">
            <h2 class="heading-md text-navy-900 mb-6">Stuur een bericht</h2>
            <form id="contact-form" class="space-y-5">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                  <label for="naam" class="block text-sm font-medium text-slate-700 mb-1">Naam</label>
                  <input type="text" id="naam" name="naam" required
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-accent focus:ring-2 focus:ring-accent/20 transition-all outline-none" />
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium text-slate-700 mb-1">E-mailadres</label>
                  <input type="email" id="email" name="email" required
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-accent focus:ring-2 focus:ring-accent/20 transition-all outline-none" />
                </div>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                  <label for="telefoon" class="block text-sm font-medium text-slate-700 mb-1">Telefoonnummer</label>
                  <input type="tel" id="telefoon" name="telefoon"
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-accent focus:ring-2 focus:ring-accent/20 transition-all outline-none" />
                </div>
                <div>
                  <label for="bedrijf" class="block text-sm font-medium text-slate-700 mb-1">Bedrijfsnaam</label>
                  <input type="text" id="bedrijf" name="bedrijf"
                    class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-accent focus:ring-2 focus:ring-accent/20 transition-all outline-none" />
                </div>
              </div>
              <div>
                <label for="bericht" class="block text-sm font-medium text-slate-700 mb-1">Bericht</label>
                <textarea id="bericht" name="bericht" rows="5" required
                  class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-accent focus:ring-2 focus:ring-accent/20 transition-all outline-none resize-none"></textarea>
              </div>
              <input type="hidden" name="_gotcha" value="" />
              <button type="submit" class="btn-primary w-full md:w-auto justify-center">
                Verstuur bericht
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </button>
            </form>
              <div id="contact-success" class="hidden p-6 rounded-2xl bg-emerald-50 border border-emerald-200 text-center mt-6">
                <div class="w-12 h-12 rounded-full bg-emerald-100 flex items-center justify-center mx-auto mb-3">
                  <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <p class="text-emerald-800 font-semibold text-lg mb-1">Bericht verzonden</p>
                <p class="text-emerald-600 text-sm">Bedankt! U hoort binnen 24 uur van Wijnand.</p>
              </div>
              <div id="contact-error" class="hidden p-6 rounded-2xl bg-red-50 border border-red-200 text-center mt-6">
                <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center mx-auto mb-3">
                  <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </div>
                <p class="text-red-800 font-semibold text-lg mb-1">Niet gelukt</p>
                <p class="text-red-600 text-sm">Probeer het later opnieuw of bel direct: <a href="tel:+31712032103" class="underline">071 - 203 2103</a></p>
              </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data: Record<string, string> = {};
    new FormData(form).forEach((v, k) => { data[k] = String(v); });
    data._ts = String(Date.now());
    try {
      const response = await fetch('https://forms.bollenstreekdigitaal.nl/api/v1/s/f_e6de503e1d49', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      if (!response.ok) throw new Error('Server error');
      form.style.display = 'none';
      document.getElementById('contact-success')?.classList.remove('hidden');
    } catch {
      document.getElementById('contact-error')?.classList.remove('hidden');
    }
  });

  // Geometric Spirograph
  const geoCanvas = document.getElementById('geo-spirograph') as HTMLCanvasElement;
  if (geoCanvas) {
    const gCtx = geoCanvas.getContext('2d')!;

    type DrawFn = (ctx: CanvasRenderingContext2D, radius: number, sides?: number) => void;
    const figs: Record<string, DrawFn> = {
      polygon(ctx, radius, sides = 4) { ctx.beginPath(); for (let i = 0; i <= sides; i++) { const a = (Math.PI * 2 * i) / sides - Math.PI / 2; const x = radius * Math.cos(a), y = radius * Math.sin(a); i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y); } ctx.closePath(); },
      circle(ctx, radius) { ctx.beginPath(); ctx.arc(radius * 0.5, 0, radius * 0.5, 0, Math.PI * 2); ctx.closePath(); },
      ellipse(ctx, radius) { ctx.beginPath(); ctx.ellipse(0, 0, radius, radius * 0.4, 0, 0, Math.PI * 2); ctx.closePath(); },
      star(ctx, radius) { ctx.beginPath(); for (let i = 0; i < 10; i++) { const a = (Math.PI * 2 * i) / 10 - Math.PI / 2, r = i % 2 === 0 ? radius : radius * 0.4; i === 0 ? ctx.moveTo(r * Math.cos(a), r * Math.sin(a)) : ctx.lineTo(r * Math.cos(a), r * Math.sin(a)); } ctx.closePath(); },
      arc(ctx, radius) { ctx.beginPath(); ctx.arc(radius * 0.4, 0, radius * 0.6, -Math.PI * 0.5, Math.PI * 0.5); },
      crescent(ctx, radius) { ctx.beginPath(); ctx.arc(0, 0, radius, -Math.PI * 0.4, Math.PI * 0.4); ctx.arc(radius * 0.3, 0, radius * 0.75, Math.PI * 0.35, -Math.PI * 0.35, true); ctx.closePath(); },
      lemniscate(ctx, radius) { ctx.beginPath(); for (let i = 0; i <= 80; i++) { const t = (Math.PI * 2 * i) / 80, d = 1 + Math.sin(t) ** 2, x = (radius * Math.cos(t)) / d, y = (radius * Math.sin(t) * Math.cos(t)) / d; i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y); } ctx.closePath(); },
    };

    interface Pat { figure: string; sides?: number; angle: number; }
    const pats: Pat[] = [
      { figure: 'polygon', sides: 4, angle: 10 }, { figure: 'circle', angle: 30 },
      { figure: 'ellipse', angle: 12 }, { figure: 'star', angle: 24 },
      { figure: 'arc', angle: 12 }, { figure: 'crescent', angle: 18 },
      { figure: 'lemniscate', angle: 15 }, { figure: 'polygon', sides: 3, angle: 15 },
      { figure: 'polygon', sides: 6, angle: 9 }, { figure: 'star', angle: 9 },
    ];

    let pIdx = 0, step = 0;
    let gPhase: 'drawing' | 'holding' | 'fading' | 'waiting' = 'drawing';
    let gFade = 1, gHold = 0, gWait = 0;
    let off: HTMLCanvasElement, oCtx: CanvasRenderingContext2D;

    function gInit() {
      const w = geoCanvas.width, h = geoCanvas.height;
      off = document.createElement('canvas'); off.width = w; off.height = h;
      oCtx = off.getContext('2d')!; oCtx.clearRect(0, 0, w, h);
      step = 0; gPhase = 'drawing'; gFade = 1;
    }

    function gResize() {
      const dpr = window.devicePixelRatio || 1;
      const w = geoCanvas.offsetWidth, h = geoCanvas.offsetHeight;
      geoCanvas.width = w * dpr; geoCanvas.height = h * dpr;
      gCtx.setTransform(dpr, 0, 0, dpr, 0, 0);
      gInit();
    }
    gResize();
    window.addEventListener('resize', gResize);

    function gDraw() {
      const w = geoCanvas.offsetWidth, h = geoCanvas.offsetHeight;
      const p = pats[pIdx], total = 360 / p.angle;
      const cx = w / 2, cy = h / 2, radius = Math.min(w, h) * 0.35;

      gCtx.clearRect(0, 0, w, h);

      if (gPhase === 'drawing') {
        if (step < total) {
          const rot = (step * p.angle * Math.PI) / 180;
          const hue = (step / total) * 360;
          oCtx.save(); oCtx.translate(cx, cy); oCtx.rotate(rot); oCtx.globalAlpha = 0.7;
          oCtx.strokeStyle = `hsl(${hue}, 70%, 60%)`; oCtx.lineWidth = 1.5;
          if (p.figure === 'polygon') figs.polygon(oCtx, radius, p.sides);
          else figs[p.figure]?.(oCtx, radius);
          oCtx.stroke(); oCtx.globalAlpha = 1; oCtx.restore();
          step++;
        } else { gPhase = 'holding'; gHold = 90; }
      } else if (gPhase === 'holding') { gHold--; if (gHold <= 0) gPhase = 'fading'; }
      else if (gPhase === 'fading') { gFade -= 0.02; if (gFade <= 0) { gPhase = 'waiting'; gWait = 20; } }
      else if (gPhase === 'waiting') { gWait--; if (gWait <= 0) { pIdx = (pIdx + 1) % pats.length; gInit(); } }

      gCtx.globalAlpha = Math.max(0, gFade);
      gCtx.drawImage(off, 0, 0, off.width, off.height, 0, 0, w, h);
      gCtx.globalAlpha = 1;

      requestAnimationFrame(gDraw);
    }
    gDraw();
  }
</script>
