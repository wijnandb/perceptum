<section class="gradient-navy relative overflow-hidden">
  <div class="absolute inset-0">
    <div class="absolute top-10 left-[20%] w-64 h-64 bg-accent/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-[20%] w-48 h-48 bg-navy-600/20 rounded-full blur-3xl"></div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>
  </div>

  <div class="container-narrow mx-auto px-6 py-20 md:py-28 text-center relative z-10">
    <h2 class="heading-lg text-white mb-6 text-balance animate-on-scroll">
      Heeft u een concreet vraagstuk?
    </h2>
    <p class="text-slate-300 text-lg mb-10 max-w-xl mx-auto animate-on-scroll delay-1">
      Wij denken graag een halfuur met u mee. Geen verplichtingen, geen verkooppraatje.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center animate-on-scroll delay-2">
      <a href="/contact/" class="btn-primary">
        Neem contact op
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a href="tel:+31712032103" class="btn-secondary">
        Bel 071 - 203 2103
      </a>
    </div>
  </div>
</section>
